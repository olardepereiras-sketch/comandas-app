# ===========================================
# CONFIGURACIÓN DEL PROYECTO RESERVAMESA
# ===========================================

# 🌐 URL de la API (Backend)
# Esta variable define dónde el FRONTEND buscará la API del backend
#
# ⚠️ MUY IMPORTANTE:
# - El frontend (app React Native) llama a esta URL desde el navegador/dispositivo del usuario
# - Si usas localhost, solo funcionará en tu máquina local
# - En producción, DEBES usar la IP pública del VPS o tu dominio
#
# 📝 CONFIGURACIÓN POR ENTORNO:
#
# 🖥️ Desarrollo Local:
# EXPO_PUBLIC_RORK_API_BASE_URL=http://localhost:3000
#
# 🚀 Producción VPS (sin dominio):
# EXPO_PUBLIC_RORK_API_BASE_URL=http://200.234.236.133
# (Reemplaza 200.234.236.133 con la IP de tu VPS)
#
# 🔒 Producción con HTTPS:
# EXPO_PUBLIC_RORK_API_BASE_URL=https://reservamesa.com
# (Reemplaza con tu dominio)
#
# ✅ EJEMPLO DE CONFIGURACIÓN CORRECTA:
EXPO_PUBLIC_RORK_API_BASE_URL=http://localhost:3000

# 🔗 URL base de la API (opcional, generalmente igual que RORK_API_BASE_URL)
# Algunos componentes pueden usar esta variable como alternativa
EXPO_PUBLIC_API_URL=http://localhost:3000

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# ===========================================
# BASE DE DATOS POSTGRESQL (LOCAL EN VPS)
# ===========================================
# PostgreSQL se ejecutará localmente en tu VPS, no necesitas servicios externos
#
# ⚠️ FORMATO DE LA URL DE CONEXIÓN:
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_bd
#
# 📝 COMPONENTES:
# - usuario: nombre de usuario de PostgreSQL (default: postgres)
# - contraseña: la que configures durante la instalación
# - host: localhost (o 127.0.0.1) si está en el mismo servidor
# - puerto: 5432 (puerto por defecto de PostgreSQL)
# - nombre_bd: el nombre de tu base de datos (ej: reservamesa_db)
#
# ✅ EJEMPLOS:
# 
# 🖥️ Desarrollo local:
# DATABASE_URL=postgresql://postgres:mipassword@localhost:5432/reservamesa_db
#
# 🚀 Producción en VPS (conexión local):
# DATABASE_URL=postgresql://reservamesa_user:password_segura@localhost:5432/reservamesa_db
#
# 🔒 Producción con SSL (si lo configuras):
# DATABASE_URL=postgresql://user:pass@localhost:5432/db?sslmode=require
#
# ⚠️ IMPORTANTE:
# - NO uses comillas en la URL
# - La contraseña NO debe contener caracteres especiales como @, :, / sin codificar
# - Si tu contraseña tiene caracteres especiales, usa codificación URL (%20 para espacios, etc.)
#
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/reservamesa_db

# Variables de entorno adicionales para producción
NODE_ENV=development

# Host del servidor (0.0.0.0 para permitir conexiones externas en VPS)
HOST=0.0.0.0
